{
  "compilerOptions": {
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "esnext"
    ],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": false,
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    // Declared explicitly: pnpm's non-hoisted layout defeats implicit @types discovery.
    "types": [
      "node",
      "jest"
    ],
    "paths": {
      "@backend/*": ["./*"],
      "@web/*": ["../web/*"]
    }
  },
  "exclude": [
    "node_modules",
    "cdk.out"
  ]
}
